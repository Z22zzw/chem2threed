# DeepSeek API Key (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# EdgeOne 部署方式：mcporter（默认，免登录）| cli（需 Token）| auto（优先 mcporter，失败回退 cli）
EDGEONE_DEPLOY_METHOD=auto

# EdgeOne Pages Token（仅 CLI 方式需要，mcporter 方式无需配置）
# 获取地址：https://console.cloud.tencent.com/edgeone/pages?tab=settings
EDGEONE_TOKEN=

# Server
PORT=3000
NODE_ENV=development

# Optional: override DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: 部署到 EdgeOne Makers 时由平台注入，本地无需配置
# Makers 会自动为 Node 服务分配端口，无需手动设置 PORT
