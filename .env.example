# LLM Gateway Configuration
# Primary: EdgeOne Makers / OpenAI-compatible LLM API credentials
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=https://your-openai-compatible-endpoint/v1

# Optional: model name.
# If omitted, the app picks a default from the endpoint:
# - DeepSeek endpoint -> deepseek-chat
# - OpenAI endpoint -> gpt-4o-mini
# - EdgeOne Makers endpoint -> @makers/deepseek-v4-flash
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# Alias variables are also supported:
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
